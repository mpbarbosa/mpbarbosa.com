# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = off

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# JavaScript/TypeScript
[*.{js,mjs,cjs,ts,jsx,tsx}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 4

# HTML files
[*.html]
indent_style = space
indent_size = 2

# CSS/SASS
[*.{css,scss,sass}]
indent_style = space
indent_size = 2

# Package.json (different convention)
[package.json]
indent_style = space
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
