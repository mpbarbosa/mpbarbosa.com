/**
 * Pure function to validate top tracks request inputs
 * @param {string} accessToken - Spotify access token
 * @param {string} timeRange - Time range for top tracks (short_term, medium_term, long_term)
 * @param {number} limit - Number of tracks to return (1-50)
 * @returns {Object} Validation result with isValid boolean and processed data
 */
function validateTopTracksInputs(accessToken, timeRange, limit) {
    // Check access token
    if (!accessToken || typeof accessToken !== 'string' || !accessToken.trim()) {
        return {
            isValid: false,
            error: 'Valid access token is required'
        };
    }
    
    // Validate time range parameter
    const validTimeRanges = ['short_term', 'medium_term', 'long_term'];
    const normalizedTimeRange = timeRange || 'medium_term';
    if (!validTimeRanges.includes(normalizedTimeRange)) {
        return {
            isValid: false,
            error: 'Time range must be one of: short_term, medium_term, long_term'
        };
    }
    
    // Validate limit parameter
    const normalizedLimit = parseInt(limit) || 20;
    if (normalizedLimit < 1 || normalizedLimit > 50) {
        return {
            isValid: false,
            error: 'Limit must be between 1 and 50'
        };
    }
    
    return {
        isValid: true,
        accessToken: accessToken.trim(),
        timeRange: normalizedTimeRange,
        limit: normalizedLimit
    };
}

