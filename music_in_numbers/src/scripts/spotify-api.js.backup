/**
 * PURE: Validates input parameters for user playlists requests
 * 
 * Core validation logic:
 * - Ensures access token is provided and valid
 * - Validates limit parameter range and format
 * - Type safety for all inputs
 * 
 * @param {string} accessToken - Spotify access token to validate
 * @param {number} limit - Number of playlists to return (1-50)
 * @returns {Object} Validation result with success flag and error details
 * @throws {never} Pure function - never throws, returns error information instead
 */
function validatePlaylistsInputs(accessToken, limit) {
    if (typeof accessToken !== 'string' || accessToken.trim() === '') {
        return {
            isValid: false,
            error: 'Access token must be a non-empty string'
        };
    }
    
    const numLimit = Number(limit);
    if (isNaN(numLimit) || numLimit < 1 || numLimit > 50) {
        return {
            isValid: false,
            error: 'Limit must be a number between 1 and 50'
        };
    }
    
    return { 
        isValid: true,
        accessToken: accessToken.trim(),
        limit: numLimit
    };
}

