 */
function processTopTracksResponse(response, data) {
    if (response.ok) {
        return {
            success: true,
            tracks: data.items || [],
            statusCode: response.status
        };
    } else {
        return {
            success: false,
            tracks: [],
            statusCode: response.status,
            error: `Failed to get top tracks: ${response.status}`
        };
    }
}

